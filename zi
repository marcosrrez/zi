#!/usr/bin/env zsh
# zi — terminal intelligence layer
# https://github.com/marcosrrez/zi
# Modes: ask  fix  desc  code  edit  agent  man  ?  explain  run  log  watch
#        setup  _route  _palette  _entries  _correct

_zi_main() {
  local _ZI_VERSION="0.1.0"
  local _ZI_MODEL="${ZI_MODEL:-llama-3.3-70b-versatile}"
  local _ZI_LOG="${XDG_DATA_HOME:-$HOME/.local/share}/zi/history.jsonl"
  local _ZI_LAST_CMD="${XDG_DATA_HOME:-$HOME/.local/share}/zi/last_cmd"
  local _ZI_PALETTE="${XDG_CONFIG_HOME:-$HOME/.config}/zi/palette"
  local _ZI_SESSION_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/zi/sessions"
  local _ZI_DB="${XDG_DATA_HOME:-$HOME/.local/share}/atuin/history.db"
  local _ZI_CLAUDE="${ZI_CLAUDE:-}"

  # Resolve claude binary
  if [[ -z "$_ZI_CLAUDE" ]]; then
    for _candidate in "$HOME/.local/bin/claude" "$(command -v claude 2>/dev/null)"; do
      [[ -x "$_candidate" ]] && { _ZI_CLAUDE="$_candidate"; break; }
    done
  fi

  # Ensure data directories exist
  mkdir -p "${_ZI_LOG:h}" "$_ZI_SESSION_DIR"

  # Source API key if not in env
  [[ -z "${GROQ_API_KEY:-$GROQ:-}" ]] && [[ -f "$HOME/.api_keys" ]] && source "$HOME/.api_keys"
  local _ZI_KEY="${ZI_GROQ_KEY:-${GROQ_API_KEY:-${GROQ:-}}}"

  # ── Groq API ───────────────────────────────────────────────────────────
  _zi_groq() {
    local prompt="$1" max_tokens="${2:-600}"
    [[ -z "$_ZI_KEY" ]] && {
      printf 'zi: GROQ_API_KEY not set. Get a free key at console.groq.com\n' >&2
      return 1
    }

    local payload
    payload=$(ZI_MODEL="$_ZI_MODEL" ZI_MAX="$max_tokens" python3 -c '
import json, sys, os
print(json.dumps({
  "model": os.environ["ZI_MODEL"],
  "messages": [{"role": "user", "content": sys.stdin.read()}],
  "max_tokens": int(os.environ.get("ZI_MAX", "600")),
  "temperature": 0.3
}))' <<< "$prompt") || return 1

    local raw
    raw=$(curl -sf https://api.groq.com/openai/v1/chat/completions \
      -H "Authorization: Bearer $_ZI_KEY" \
      -H "Content-Type: application/json" \
      -d "$payload") || { printf 'zi: API request failed\n' >&2; return 1; }

    python3 -c "
import sys, json
d = json.load(sys.stdin)
if 'error' in d:
    print('zi: ' + d['error'].get('message', 'API error'), file=sys.stderr)
    sys.exit(1)
print(d['choices'][0]['message']['content'].strip())
" <<< "$raw"
  }

  # ── Groq API — multi-turn chat ────────────────────────────────────────
  _zi_groq_chat() {
    local messages_json="$1" system_prompt="$2" max_tokens="${3:-800}"
    [[ -z "$_ZI_KEY" ]] && { printf 'zi: GROQ_API_KEY not set\n' >&2; return 1; }

    local payload
    payload=$(ZI_MODEL="$_ZI_MODEL" ZI_MAX="$max_tokens" python3 -c "
import json, sys, os
messages = json.loads(sys.argv[1])
system = sys.argv[2] if len(sys.argv) > 2 and sys.argv[2] else None
all_msgs = []
if system:
    all_msgs.append({'role': 'system', 'content': system})
all_msgs.extend(messages)
print(json.dumps({
  'model': os.environ['ZI_MODEL'],
  'messages': all_msgs,
  'max_tokens': int(os.environ.get('ZI_MAX', '800')),
  'temperature': 0.7
}))
" "$messages_json" "${system_prompt:-}") || return 1

    local raw
    raw=$(curl -sf https://api.groq.com/openai/v1/chat/completions \
      -H "Authorization: Bearer $_ZI_KEY" \
      -H "Content-Type: application/json" \
      -d "$payload") || { printf 'zi: API request failed\n' >&2; return 1; }

    python3 -c "
import sys, json
d = json.load(sys.stdin)
if 'error' in d:
    print('zi: ' + d['error'].get('message', 'API error'), file=sys.stderr)
    sys.exit(1)
print(d['choices'][0]['message']['content'].strip())
" <<< "$raw"
  }

  # ── Auto-detect installed tools for context ────────────────────────────
  _zi_detect_tools() {
    local tools=()
    local candidates=(
      git gh docker brew npm node python3 ruby go cargo make cmake
      jq yq fzf fd rg bat eza dust duf zoxide atuin lazygit tmux
      zellij nvim vim code kubectl terraform ansible ffmpeg rsync
    )
    for t in "${candidates[@]}"; do
      command -v "$t" &>/dev/null && tools+=("$t")
    done
    printf '%s' "${(j:, :)tools}"
  }

  # ── Shell context injected into every prompt ───────────────────────────
  _zi_context() {
    local branch os_name tools
    branch=$(git branch --show-current 2>/dev/null)
    os_name=$(uname -s)
    tools=$(_zi_detect_tools)
    printf 'OS: %s, shell: zsh, cwd: %s%s\nAvailable tools: %s\n' \
      "$os_name" "$PWD" "${branch:+, git: $branch}" "$tools"
  }

  # ── Post-edit diff display ────────────────────────────────────────────
  _zi_show_diff() {
    git rev-parse --is-inside-work-tree &>/dev/null || return 0
    local changed
    changed=$(git diff --name-only 2>/dev/null)
    [[ -z "$changed" ]] && return 0
    printf '\n\033[2m── changed files ──────────────────────────────────\033[0m\n'
    echo "$changed" | while read -r f; do
      printf '  \033[1;33m~\033[0m  %s\n' "$f"
    done
    printf '\033[2m───────────────────────────────────────────────────\033[0m\n'
    printf 'Show diff? [y/N/p=paged] '
    read -r _d
    case "$_d" in
      y|Y)
        if command -v delta &>/dev/null; then
          git diff | delta
        elif command -v bat &>/dev/null; then
          git diff | bat --language diff --style plain
        else
          git diff --color
        fi ;;
      p|P)
        if command -v delta &>/dev/null; then
          git diff | delta | less -R
        else
          git diff --color | less -R
        fi ;;
    esac
  }

  # ── Logging ────────────────────────────────────────────────────────────
  _zi_log_entry() {
    local mode="$1" query="$2" response="$3"
    python3 -c "
import json, sys
from datetime import datetime, timezone
e = {'ts': datetime.now(timezone.utc).isoformat(), 'mode': sys.argv[1], 'query': sys.argv[2], 'response': sys.argv[3]}
print(json.dumps(e))
" "$mode" "$query" "$response" >> "$_ZI_LOG" 2>/dev/null
  }

  # ── Last failed command (Atuin → preexec file → fc fallback) ─────────
  _zi_last_failed() {
    if [[ -f "$_ZI_DB" ]]; then
      sqlite3 -separator '|' "$_ZI_DB" \
        "SELECT command, exit FROM history WHERE command NOT LIKE 'zi%' AND exit != 0 ORDER BY timestamp DESC LIMIT 1;" 2>/dev/null
    elif [[ -f "$_ZI_LAST_CMD" ]]; then
      cat "$_ZI_LAST_CMD"
    else
      fc -ln -1 2>/dev/null | sed 's/^[[:space:]]//'
    fi
  }

  # ── Default palette entries ────────────────────────────────────────────
  _zi_default_entries() {
    cat << 'ENTRIES'
git     |git status                    |Working tree status
git     |git log --oneline --graph -20 |Commit graph (last 20)
git     |git diff --staged             |Review staged changes
git     |git stash                     |Stash current changes
git     |git stash pop                 |Restore latest stash
git     |git pull --rebase             |Pull and rebase on top
git     |git push                      |Push current branch
nav     |cd -                          |Jump to previous directory
nav     |ls -la                        |List all files with details
nav     |pwd                           |Show current directory
files   |find . -name <pattern>        |Find files by name
files   |grep -r <pattern> .           |Search file contents (grep)
files   |cat <file>                    |View file contents
files   |cp -r <src> <dst>             |Copy file or directory
files   |mv <src> <dst>                |Move or rename
files   |rm -rf <path>                 |Delete file or directory
files   |du -sh *                      |Directory sizes
files   |chmod +x <file>               |Make file executable
sys     |ps aux | grep <name>          |Find a running process
sys     |kill -9 <pid>                 |Force-kill a process
sys     |top                           |System monitor
sys     |df -h                         |Disk usage overview
sys     |curl -fsSL <url>              |Download a URL
sys     |ping -c 3 <host>              |Check connectivity
zi      |zi <anything>                 |Smart intent routing
zi      |zi ask <query>                |Natural language to command
zi      |zi code <task>                |Generate code (Claude or Groq)
zi      |zi edit <task>                |Claude edits files autonomously
zi      |zi agent <task>               |Claude fully autonomous
zi      |zi desc <cmd>                 |Explain what a command does
zi      |zi fix                        |Explain + fix last error
zi      |zi man <cmd>                  |Summarize man page
zi      |zi chat                       |Start or resume a conversation
zi      |zi chat list                  |List saved chat sessions
zi      |zi watch on                   |Auto-fix on non-zero exit
zi      |zi update                     |Update zi to latest version
ENTRIES
  }

  # ── Palette entries (defaults + user overrides) ────────────────────────
  _zi_entries() {
    _zi_default_entries
    [[ -f "$_ZI_PALETTE" ]] && cat "$_ZI_PALETTE"
  }

  # ── Intent router ──────────────────────────────────────────────────────
  _zi_route() {
    local input="$*"
    local lower="${input:l}"
    local first_word="${input%% *}"

    # File path that exists → explain
    if [[ "$first_word" == /* || "$first_word" == ~* || "$first_word" == ./* ]]; then
      local resolved="${first_word/#\~/$HOME}"
      [[ -f "$resolved" ]] && { _zi_main explain "$resolved"; return; }
    fi

    # Error/failure intent → fix
    if echo "$lower" | grep -qE '(why.*(fail|error|broke|not work|crash)|fix (this|the|my)|what.*(went wrong|is wrong))'; then
      _zi_main fix
      return
    fi

    # File editing intent → edit
    if echo "$lower" | grep -qE '^(refactor|add|remove|update|rename|fix|change|edit|modify).*(in |to |the ).*(\.js|\.ts|\.py|\.sh|\.zsh|\.md|\.json|\.yaml|\.go|\.rb|file|function|class|component)'; then
      _zi_main edit "$input"
      return
    fi

    # "what does X do" or "explain X" → desc
    if echo "$lower" | grep -qE '^(what does|explain|describe|what is) .*(command|flag|option|do\??$)'; then
      local subject
      subject=$(echo "$input" | sed -E 's/^(what does|explain|describe|what is) //i' \
                              | sed -E 's/ (command|flag|option|do)\??$//i' \
                              | awk '{print $1}')
      [[ -n "$subject" ]] && { _zi_main desc "$subject"; return; }
    fi

    # Known CLI binary with few words → desc
    local known_clis=(git ls find grep awk sed curl wget ssh docker brew npm node python python3 ruby go cargo make cmake gcc ffmpeg rsync tar jq yq fzf fd rg bat eza dust duf zoxide lazygit gh kubectl terraform)
    if (( ${known_clis[(Ie)$first_word]} )) && [[ $(echo "$input" | wc -w) -le 6 ]]; then
      _zi_main desc "$input"
      return
    fi

    # Code generation → code
    if echo "$lower" | grep -qE '^(write|create|build|generate|make me|scaffold|draft).*(script|function|class|program|tool|app|api|server|cli|hook|plugin|module|file)'; then
      _zi_main code "$input"
      return
    fi

    # Default → ask
    _zi_main ask "$input"
  }

  # ── Modes ──────────────────────────────────────────────────────────────
  case "$1" in

    "version"|"--version"|"-v")
      printf 'zi v%s\n' "$_ZI_VERSION"
      ;;

    "update")
      local _bin_path
      _bin_path=$(command -v zi 2>/dev/null || printf '%s/.local/bin/zi' "$HOME")
      local _zsh_path="${XDG_CONFIG_HOME:-$HOME/.config}/zi/zi.zsh"
      local _base="https://raw.githubusercontent.com/marcosrrez/zi/main"

      printf '\033[2mchecking for updates...\033[0m\n'
      local _remote_ver
      _remote_ver=$(curl -sf "$_base/VERSION" | tr -d '[:space:]') || {
        printf 'zi: could not reach GitHub\n' >&2; return 1
      }

      if [[ "$_remote_ver" == "$_ZI_VERSION" ]]; then
        printf 'zi is up to date (v%s)\n' "$_ZI_VERSION"
        return 0
      fi

      printf 'Updating v%s → v%s\n' "$_ZI_VERSION" "$_remote_ver"
      curl -fsSL "$_base/zi" -o "${_bin_path}.tmp" \
        && chmod +x "${_bin_path}.tmp" \
        && mv "${_bin_path}.tmp" "$_bin_path" || {
          rm -f "${_bin_path}.tmp"
          printf 'zi: update failed\n' >&2; return 1
        }
      curl -fsSL "$_base/zi.zsh" -o "$_zsh_path" 2>/dev/null || true
      printf '\033[0;32mUpdated to v%s\033[0m\n' "$_remote_ver"
      printf 'Restart your shell or run: source %s\n' "$_zsh_path"
      ;;

    "chat")
      shift
      local _subcmd="$1"

      # zi chat list
      if [[ "$_subcmd" == "list" ]]; then
        local _found=0
        for _f in "$_ZI_SESSION_DIR"/*.jsonl(N); do
          local _name="${_f:t:r}"
          local _count
          _count=$(wc -l < "$_f" | tr -d ' ')
          printf '  \033[1;35m%-20s\033[0m %s messages\n' "$_name" "$(( _count / 2 ))"
          _found=1
        done
        [[ $_found -eq 0 ]] && printf 'zi: no chat sessions yet\n'
        return 0
      fi

      local _session="${_subcmd:-default}"
      local _session_file="$_ZI_SESSION_DIR/$_session.jsonl"
      local _system_base="You are zi, a helpful terminal assistant. Be concise. When suggesting shell commands, put them on their own line prefixed with \$."

      printf '\033[2mzi chat — session: \033[1;35m%s\033[0m\n' "$_session"
      if [[ -f "$_session_file" ]]; then
        local _msg_count
        _msg_count=$(wc -l < "$_session_file" | tr -d ' ')
        printf '\033[2mResuming (%d messages). /exit /list /new <name> /clear /help\033[0m\n\n' "$(( _msg_count / 2 ))"
      else
        printf '\033[2mNew session. /exit /list /new <name> /clear /help\033[0m\n\n'
      fi

      while true; do
        printf '\033[1;35mYou › \033[0m'
        read -r _input || break
        [[ -z "$_input" ]] && continue

        case "$_input" in
          /exit|/quit)
            printf '\033[2msession saved: %s\033[0m\n' "$_session"
            break ;;
          /list)
            _zi_main chat list; continue ;;
          /new*)
            local _new="${_input#/new}"
            _new="${_new## }"
            _session="${_new:-default}"
            _session_file="$_ZI_SESSION_DIR/$_session.jsonl"
            printf '\033[2mswitched to: %s\033[0m\n' "$_session"
            continue ;;
          /clear)
            > "$_session_file"
            printf '\033[2msession cleared\033[0m\n'
            continue ;;
          /help)
            printf '  /exit        quit (session auto-saved)\n'
            printf '  /list        show all sessions\n'
            printf '  /new <name>  switch to or create named session\n'
            printf '  /clear       clear current session history\n'
            continue ;;
        esac

        # Append user message to session file
        python3 -c "
import json, sys
print(json.dumps({'role': 'user', 'content': sys.argv[1]}))" "$_input" >> "$_session_file"

        # Build messages array from session file
        # Build messages (capped at 40 to control token usage)
        local _messages
        _messages=$(python3 -c "
import json, sys, os
path = sys.argv[1]
msgs = []
if os.path.exists(path):
    for line in open(path):
        try: msgs.append(json.loads(line))
        except: pass
print(json.dumps(msgs[-40:]))" "$_session_file")

        # Re-inject fresh context on every turn (picks up cwd changes)
        local _system="$(_zi_context)
$_system_base"

        printf '\033[2mthinking...\033[0m'
        local _response
        _response=$(_zi_groq_chat "$_messages" "$_system") || { printf '\r\033[K'; continue; }
        printf '\r\033[K'

        printf '\033[1;36mzi  › \033[0m%s\n\n' "$_response"
        _zi_log_entry "chat" "$_input" "$_response"

        # Append assistant response
        python3 -c "
import json, sys
print(json.dumps({'role': 'assistant', 'content': sys.argv[1]}))" "$_response" >> "$_session_file"
      done
      ;;

    "_palette")
      _zi_entries \
        | fzf \
          --delimiter='|' \
          --with-nth='1,3' \
          --nth='2,3' \
          --prompt='zi › ' \
          --height='40%' \
          --border='rounded' \
          --color='prompt:#c6a0f6,pointer:#ed8796,border:#363a4f,hl:#eed49f,hl+:#eed49f,info:#6e738d' \
          --header='Enter: run   Ctrl+y: copy   Esc: cancel' \
          --bind="ctrl-y:execute-silent(echo {2} | xargs | pbcopy)+abort" \
          --preview='printf "  \033[1;35m%s\033[0m\n  \033[2m%s\033[0m\n" "$(echo {2} | xargs)" "$(echo {3} | xargs)"' \
          --preview-window='down:3:wrap' \
      | awk -F'|' '{gsub(/^[[:space:]]+|[[:space:]]+$/, "", $2); print $2}'
      ;;

    "_entries")
      _zi_entries
      ;;

    "_correct")
      shift
      [[ -z "$*" ]] && return 0
      _zi_groq "Fix typos or syntax errors in this shell command on $(uname -s). Reply with ONLY the corrected command, no backticks, no explanation:
$*"
      ;;

    "_route")
      shift
      _zi_route "$@"
      ;;

    "ask")
      shift
      local q="$*"
      [[ -z "$q" ]] && { printf 'zi ask › '; read -r q; }
      printf '\033[2mthinking...\033[0m\n'
      local cmd
      cmd=$(_zi_groq "$(_zi_context)

Convert to a shell one-liner (pipes, subshells, and command substitution are fine). Reply with ONLY the command, no backticks, no explanation:
$q") || return 1
      printf '\n  \033[1;35m%s\033[0m\n\n' "$cmd"
      printf 'Run? [y/N/c=copy] '
      read -r ans
      case "$ans" in
        y|Y) _zi_log_entry "ask" "$q" "$cmd"; eval "$cmd" ;;
        c|C) printf '%s' "$cmd" | pbcopy; printf '\033[2mcopied\033[0m\n'; _zi_log_entry "ask" "$q" "$cmd" ;;
        *)   _zi_log_entry "ask" "$q" "$cmd" ;;
      esac
      ;;

    "fix")
      local raw_last cmd exit_code err
      raw_last=$(_zi_last_failed)
      if [[ "$raw_last" == *'|'* ]]; then
        cmd="${raw_last%%|*}"
        exit_code="${raw_last##*|}"
      else
        cmd="$raw_last"
        exit_code="?"
      fi

      if [[ ! -t 0 ]]; then
        err=$(cat)
      elif [[ -n "$TMUX" ]]; then
        err=$(tmux capture-pane -p -S - 2>/dev/null | tail -60)
      else
        printf '\033[2mlast failed: %s (exit: %s)\033[0m\n' "$cmd" "$exit_code"
        printf 'Paste error output (Ctrl+D to skip, or pipe: cmd 2>&1 | zi fix):\n'
        err=$(cat)
      fi

      printf '\033[2manalyzing...\033[0m\n'
      local response
      response=$(_zi_groq "Command: $cmd
Exit code: $exit_code
Error output:
$err

Reply in this exact format:
Issue: <one line explanation>
Fix:   <corrected command only>") || return 1
      printf '\n%s\n\n' "$response"
      _zi_log_entry "fix" "$cmd" "$response"
      ;;

    "desc")
      shift
      [[ -z "$*" ]] && { printf 'Usage: zi desc <command or snippet>\n'; return 1; }
      printf '\033[2mexplaining...\033[0m\n'
      local response
      response=$(_zi_groq "Explain what this shell command or snippet does, in plain English. One sentence summary, then bullet any non-obvious flags or behaviors. No preamble:
$*" 300) || return 1
      printf '\n%s\n\n' "$response"
      _zi_log_entry "desc" "$*" "$response"
      ;;

    "code")
      shift
      local q="$*"
      [[ -z "$q" ]] && { printf 'zi code › '; read -r q; }
      if [[ -x "$_ZI_CLAUDE" ]]; then
        printf '\033[2mrouting to Claude...\033[0m\n'
        local prompt="$(_zi_context)

Write clean, working code for the following task. Include only the code and brief inline comments where non-obvious. No preamble, no markdown fences:
$q"
        _zi_log_entry "code" "$q" "(claude)"
        printf '%s' "$prompt" | "$_ZI_CLAUDE" --print -
      else
        printf '\033[2mthinking...\033[0m\n'
        local response
        response=$(_zi_groq "$(_zi_context)

Write clean, working code for the following task. Include only the code and brief inline comments where non-obvious. No preamble:
$q" 1200) || return 1
        printf '\n%s\n\n' "$response"
        _zi_log_entry "code" "$q" "$response"
      fi
      ;;

    "edit")
      shift
      local q="$*"
      [[ -z "$q" ]] && { printf 'zi edit › '; read -r q; }
      [[ ! -x "$_ZI_CLAUDE" ]] && { printf 'zi: claude CLI not found. Install Claude Code to use zi edit.\n' >&2; return 1; }
      printf '\033[2mzi edit — Claude will edit files autonomously (bash requires approval)\033[0m\n'
      printf '\033[2mtask: %s\033[0m\n\n' "$q"
      _zi_log_entry "edit" "$q" "(claude:acceptEdits)"
      "$_ZI_CLAUDE" --permission-mode acceptEdits "$q"
      _zi_show_diff
      ;;

    "agent")
      shift
      local q="$*"
      [[ -z "$q" ]] && { printf 'zi agent › '; read -r q; }
      [[ ! -x "$_ZI_CLAUDE" ]] && { printf 'zi: claude CLI not found. Install Claude Code to use zi agent.\n' >&2; return 1; }
      printf '\033[1;33mWARNING: zi agent bypasses all permission checks.\033[0m\n'
      printf '\033[1;33mClaude will edit files and run commands without asking.\033[0m\n'
      printf 'Continue? [y/N] '
      read -r confirm
      [[ "$confirm" != y && "$confirm" != Y ]] && { printf '\033[2maborted\033[0m\n'; return 0; }
      printf '\n\033[2mzi agent — running autonomously...\033[0m\n\n'
      _zi_log_entry "agent" "$q" "(claude:bypassPermissions)"
      "$_ZI_CLAUDE" --permission-mode bypassPermissions "$q"
      _zi_show_diff
      ;;

    "man")
      shift
      [[ -z "$1" ]] && { printf 'Usage: zi man <command>\n'; return 1; }
      local mantext
      mantext=$(man "$1" 2>/dev/null | col -bx | head -200) || {
        printf 'zi: no man page for %s\n' "$1" >&2; return 1
      }
      printf '\033[2mreading %s man page...\033[0m\n' "$1"
      local response
      response=$(_zi_groq "Summarize the most useful flags and common usage patterns for '$1'. 10 bullet points max, practical examples only, no preamble:
$mantext" 300) || return 1
      printf '\n%s\n\n' "$response"
      _zi_log_entry "man" "$1" "$response"
      ;;

    "?")
      shift
      local text
      if [[ ! -t 0 ]]; then
        text=$(cat)
      else
        text="$*"
      fi
      [[ -z "$text" ]] && { printf 'Usage: zi ? <text>  or  cmd | zi ?\n'; return 1; }
      printf '\033[2mexplaining...\033[0m\n'
      local response
      response=$(_zi_groq "Explain what this terminal output means and what action (if any) to take. Be concise. No preamble:
$text" 200) || return 1
      printf '\n%s\n\n' "$response"
      _zi_log_entry "?" "$text" "$response"
      ;;

    "explain")
      shift
      local target="$1"
      [[ -z "$target" ]] && { printf 'Usage: zi explain <file>\n'; return 1; }
      [[ ! -f "$target" ]] && { printf 'zi: file not found: %s\n' "$target" >&2; return 1; }
      local content
      content=$(head -200 "$target")
      printf '\033[2mexplaining %s...\033[0m\n' "$target"
      local response
      response=$(_zi_groq "Explain what this file does in plain English. What it is, what it does, and any non-obvious details. No preamble:
--- $target ---
$content" 400) || return 1
      printf '\n%s\n\n' "$response"
      _zi_log_entry "explain" "$target" "$response"
      ;;

    "run")
      shift
      [[ -z "$*" ]] && { printf 'Usage: zi run <command>\n'; return 1; }
      local out code
      out=$(zsh -c "$*" 2>&1); code=$?
      printf '%s\n' "$out"
      printf '%s' "$out" | pbcopy 2>/dev/null || printf '%s' "$out" | xclip -selection clipboard 2>/dev/null
      printf '\033[2mcopied to clipboard\033[0m\n'
      _zi_log_entry "run" "$*" "$out"
      return $code
      ;;

    "log")
      [[ -f "$_ZI_LOG" ]] || { printf 'zi: no history yet\n'; return 0; }
      local filter="${2:-}"
      python3 -c "
import json, sys
lines = open('$_ZI_LOG').readlines()
filt = sys.argv[1].lower() if len(sys.argv) > 1 else ''
matches = []
for line in lines:
    try:
        e = json.loads(line)
        if filt and filt not in e.get('query','').lower() and filt not in e.get('mode','').lower():
            continue
        matches.append(e)
    except: pass
for e in matches[-20:]:
    ts = e.get('ts','')[:16].replace('T',' ')
    mode = e.get('mode','?')
    query = e.get('query','')[:70]
    print(f'  \033[2m{ts}\033[0m  \033[1;35m{mode:<6}\033[0m  {query}')
" "$filter"
      ;;

    "watch")
      shift
      case "$1" in
        on)  touch "$HOME/.zi_watch";  printf '\033[2mzi watch enabled\033[0m\n' ;;
        off) rm -f "$HOME/.zi_watch";  printf '\033[2mzi watch disabled\033[0m\n' ;;
        *)   [[ -f "$HOME/.zi_watch" ]] && printf 'zi watch: on\n' || printf 'zi watch: off\n' ;;
      esac
      ;;

    "setup")
      # ── Helper output functions ──────────────────────────────────────────
      _s_line()  { printf '\n'; }
      _s_head()  { printf '\033[1;35m%s\033[0m\n' "$*"; }
      _s_ok()    { printf '  \033[0;32m✔\033[0m  %s\n' "$*"; }
      _s_warn()  { printf '  \033[0;33m!\033[0m  %s\n' "$*"; }
      _s_info()  { printf '  \033[2m%s\033[0m\n' "$*"; }
      _s_ask()   { printf '  \033[1m%s\033[0m [y/N] ' "$*"; }
      _s_input() { printf '  \033[1m%s\033[0m › ' "$*"; }
      _s_tip()   { printf '  \033[0;36m→\033[0m  %s\n' "$*"; }

      local _ZI_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/zi"
      local _ZI_PALETTE_FILE="$_ZI_CONFIG_DIR/palette"
      local _ZSHRC="${ZDOTDIR:-$HOME}/.zshrc"
      local _BEGINNER=0
      local _WORKFLOW=""
      local _INSTALL_CMD=""

      # detect package manager
      if command -v brew &>/dev/null; then
        _INSTALL_CMD="brew install"
      elif command -v apt-get &>/dev/null; then
        _INSTALL_CMD="sudo apt-get install -y"
      elif command -v dnf &>/dev/null; then
        _INSTALL_CMD="sudo dnf install -y"
      fi

      clear 2>/dev/null || true
      printf '\033[1;35m'
      cat << 'BANNER'

       ▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀
           zi — terminal intelligence
       ▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄

BANNER
      printf '\033[0m'
      _s_info "Let's get you set up. This takes about 2 minutes."
      _s_info "You can re-run 'zi setup' any time to change your config."
      _s_line

      # ── Step 1: Experience level ───────────────────────────────────────
      _s_head "Step 1 of 5 — Your experience level"
      _s_line
      printf '  How comfortable are you with the command line?\n\n'
      printf '    1) New to this — I could use some guidance\n'
      printf '    2) I know my way around\n'
      printf '    3) Power user — just get out of my way\n'
      _s_line
      _s_input "Enter 1, 2, or 3"
      read -r _level
      case "$_level" in
        1) _BEGINNER=1 ;;
        3) _BEGINNER=0 ;;
        *) _BEGINNER=0 ;;
      esac

      if [[ $_BEGINNER -eq 1 ]]; then
        _s_line
        _s_info "Got it. I'll explain things as we go."
        _s_info "zi is a tool that lets you talk to your terminal in plain English."
        _s_info "Instead of memorizing commands, you just describe what you want."
        _s_line
        _s_tip "Example: zi find all files larger than 100MB"
        _s_tip "Example: zi why did that fail"
        _s_tip "Example: zi write a script to rename all my photos"
      fi

      # ── Step 2: API key ────────────────────────────────────────────────
      _s_line
      _s_head "Step 2 of 5 — Groq API key"
      _s_line

      local _current_key="${ZI_GROQ_KEY:-${GROQ_API_KEY:-${GROQ:-}}}"
      if [[ -z "$_current_key" ]] && [[ -f "$HOME/.api_keys" ]]; then
        source "$HOME/.api_keys" 2>/dev/null
        _current_key="${ZI_GROQ_KEY:-${GROQ_API_KEY:-${GROQ:-}}}"
      fi

      if [[ -n "$_current_key" ]]; then
        _s_ok "Groq API key found (${_current_key:0:8}...)"
      else
        if [[ $_BEGINNER -eq 1 ]]; then
          _s_info "zi uses Groq to understand your requests. Groq is free."
          _s_info "Go to console.groq.com, sign up, and create an API key."
          _s_info "It takes about 60 seconds and costs nothing."
        else
          _s_warn "No Groq API key found. Get one free at console.groq.com"
        fi
        _s_line
        _s_input "Paste your Groq API key (Enter to skip)"
        read -r _key
        if [[ -n "$_key" ]]; then
          mkdir -p "$_ZI_CONFIG_DIR"
          echo "export GROQ_API_KEY=\"$_key\"" >> "$_ZSHRC"
          export GROQ_API_KEY="$_key"
          _s_ok "Key saved to $_ZSHRC"
        else
          _s_warn "Skipped. zi won't work until GROQ_API_KEY is set."
        fi
      fi

      # ── Step 3: Workflow ───────────────────────────────────────────────
      _s_line
      _s_head "Step 3 of 5 — Your workflow"
      _s_line
      if [[ $_BEGINNER -eq 1 ]]; then
        _s_info "zi will customize its command palette based on what you do."
      fi
      printf '  What best describes your work? (pick the closest one)\n\n'
      printf '    1) Web / frontend  (HTML, CSS, JavaScript, React, etc.)\n'
      printf '    2) Backend / APIs  (Node, Python, Go, databases)\n'
      printf '    3) DevOps / infra  (Docker, Kubernetes, cloud)\n'
      printf '    4) Data / ML       (Python, Jupyter, data pipelines)\n'
      printf '    5) General / mixed (a bit of everything)\n'
      _s_line
      _s_input "Enter 1–5"
      read -r _wf
      case "$_wf" in
        1) _WORKFLOW="web" ;;
        2) _WORKFLOW="backend" ;;
        3) _WORKFLOW="devops" ;;
        4) _WORKFLOW="data" ;;
        *) _WORKFLOW="general" ;;
      esac
      _s_ok "Workflow set to: $_WORKFLOW"

      # ── Step 4: Tool detection + offers ───────────────────────────────
      _s_line
      _s_head "Step 4 of 5 — Terminal tools"
      _s_line
      _s_info "The terminal has a modern toolset that makes everything faster."
      _s_info "zi works better with these installed — let's see what you have."
      _s_line

      # ── Tier renderer ──────────────────────────────────────────────────
      # _zi_tool_tier <tier_label> <tier_desc> tool1 tool2 ...
      # Each tool entry: "bin|pkg|headline|what_you_get|before|after"
      _zi_tool_tier() {
        local _tier_label="$1" _tier_desc="$2"
        shift 2
        local -a _tier_tools=("$@")
        local -a _missing_names _missing_pkgs
        local _installed_count=0

        printf '\n  \033[1;35m%s\033[0m  \033[2m%s\033[0m\n' "$_tier_label" "$_tier_desc"
        printf '  %s\n' "─────────────────────────────────────────────────────"

        for _entry in "${_tier_tools[@]}"; do
          local _bin="${_entry%%|*}"
          local _r1="${_entry#*|}"
          local _pkg="${_r1%%|*}"
          local _r2="${_r1#*|}"
          local _headline="${_r2%%|*}"
          local _r3="${_r2#*|}"
          local _what="${_r3%%|*}"
          local _r4="${_r3#*|}"
          local _before="${_r4%%|*}"
          local _after="${_r4#*|}"

          if command -v "$_bin" &>/dev/null; then
            printf '  \033[0;32m✔\033[0m  \033[1m%-12s\033[0m  %s\n' "$_bin" "$_headline"
            (( _installed_count++ ))
          else
            printf '  \033[2m○\033[0m  \033[1m%-12s\033[0m  \033[0;33m%s\033[0m\n' "$_bin" "$_headline"
            _s_info "    $_what"
            if [[ -n "$_before" && -n "$_after" ]]; then
              printf '    \033[2mbefore →\033[0m  %s\n' "$_before"
              printf '    \033[0;32mafter  →\033[0m  %s\n' "$_after"
            fi
            _missing_names+=("$_bin")
            _missing_pkgs+=("$_pkg")
          fi
        done

        if [[ ${#_missing_names[@]} -eq 0 ]]; then
          _s_line
          _s_ok "All $# tools in this tier already installed"
          return 0
        fi

        if [[ -z "$_INSTALL_CMD" ]]; then
          _s_line
          _s_warn "No package manager found. Install manually:"
          for _n in "${_missing_names[@]}"; do
            _s_info "  $_n"
          done
          return 0
        fi

        _s_line
        printf '  \033[1m%d missing.\033[0m  Install all? [Y/n/pick]\033[0m ' "${#_missing_names[@]}"
        printf '  \033[2m(Y=yes, n=skip tier, pick=choose one by one)\033[0m\n'
        printf '  › '
        read -r _tier_ans
        _tier_ans="${_tier_ans:-Y}"

        case "${_tier_ans:u}" in
          Y|YES)
            _s_line
            _s_info "Installing ${_missing_pkgs[*]}..."
            _s_line
            local _all_ok=1
            for (( _ti=1; _ti<=${#_missing_pkgs[@]}; _ti++ )); do
              local _p="${_missing_pkgs[$_ti]}"
              local _n="${_missing_names[$_ti]}"
              printf '  \033[2m▸ %s %s\033[0m\n' "$_INSTALL_CMD" "$_p"
              if eval "$_INSTALL_CMD $_p" >/dev/null 2>&1; then
                _s_ok "$_n installed"
              else
                _s_warn "$_n failed — install manually later: $_INSTALL_CMD $_p"
                _all_ok=0
              fi
            done
            ;;
          N|NO)
            _s_info "Skipped. You can install these later and re-run 'zi setup'."
            ;;
          PICK|P)
            _s_line
            for (( _ti=1; _ti<=${#_missing_pkgs[@]}; _ti++ )); do
              local _p="${_missing_pkgs[$_ti]}"
              local _n="${_missing_names[$_ti]}"
              printf '  Install \033[1m%s\033[0m? [y/N] ' "$_n"
              read -r _pick_ans
              if [[ "$_pick_ans" == y || "$_pick_ans" == Y ]]; then
                printf '  \033[2m▸ %s %s\033[0m\n' "$_INSTALL_CMD" "$_p"
                if eval "$_INSTALL_CMD $_p" >/dev/null 2>&1; then
                  _s_ok "$_n installed"
                else
                  _s_warn "$_n failed — install manually later"
                fi
              fi
            done
            ;;
          *)
            _s_info "Skipped."
            ;;
        esac
      }

      local _to_install=()  # unused now but kept for compat

      # ── Tier 1: Essential ──────────────────────────────────────────────
      _zi_tool_tier \
        "ESSENTIAL" "zi requires this to work" \
        "fzf|fzf|Fuzzy finder — powers the zi command palette|Without fzf, the zi palette (just type 'zi') won't work.|zi  →  (nothing appears)|zi  →  interactive searchable menu of 30+ commands"

      # ── Tier 2: Recommended ────────────────────────────────────────────
      _s_line
      _zi_tool_tier \
        "RECOMMENDED" "faster versions of tools you already use" \
        "fd|fd|fd — a better 'find'|10x faster than find, with sane defaults and color output.|find . -name '*.js' -not -path '*/node_modules/*'|fd '*.js'" \
        "rg|ripgrep|rg — a better 'grep'|Search file contents across a whole project in milliseconds.|grep -r 'TODO' . --include='*.py'|rg 'TODO' --type py" \
        "bat|bat|bat — a better 'cat'|Shows files with syntax highlighting, line numbers, and git diff markers.|cat server.js  →  plain text wall|bat server.js  →  color, line numbers, git markers" \
        "eza|eza|eza — a better 'ls'|Shows file sizes, git status, icons, and permissions at a glance.|ls -la  →  hard to scan|eza -la --git  →  colored, icons, git status per file"

      # ── Tier 3: Power tools ────────────────────────────────────────────
      _s_line
      _zi_tool_tier \
        "POWER TOOLS" "tools that change how you navigate and recover" \
        "zoxide|zoxide|zoxide — smart 'cd' that learns|Remembers your most-visited dirs. Jump anywhere in 2-3 chars.|cd ~/developer/myproject/src/components|z comp  →  jumps there instantly" \
        "lazygit|lazygit|lazygit — git in a visual TUI|Stage hunks, resolve conflicts, and push without memorizing git flags.|git add -p, git rebase -i, git push|lazygit  →  everything on one screen" \
        "atuin|atuin|atuin — your entire history, searchable|Stores every command with timestamp, exit code, and cwd in SQLite.|Ctrl+R  →  only matches by prefix|Ctrl+R  →  fuzzy, filtered, context-aware" \
        "dust|dust|dust — visual disk usage|See which directories are consuming space, as a tree.|du -sh *  →  unsorted numbers|dust  →  sorted visual bar chart" \
        "btm|bottom|btm — system monitor (CPU/RAM/disk/net)|A nicer top with charts for CPU, memory, disk I/O, and network.|top  →  numbers only, hard to read|btm  →  sparklines, sortable, zoomable"

      # ── Step 5: Generate personalized palette ─────────────────────────
      _s_line
      _s_head "Step 5 of 5 — Personalizing your palette"
      _s_line

      mkdir -p "$_ZI_CONFIG_DIR"
      local _palette_out=""

      case "$_WORKFLOW" in
        web)
          _palette_out+="web     |npm run dev                   |Start dev server\n"
          _palette_out+="web     |npm run build                 |Build for production\n"
          _palette_out+="web     |npm install                   |Install dependencies\n"
          _palette_out+="web     |npx prettier --write .        |Format all files\n"
          _palette_out+="web     |npx eslint .                  |Lint project\n"
          command -v node &>/dev/null && _palette_out+="web     |node --version                |Check Node version\n"
          ;;
        backend)
          _palette_out+="server  |docker compose up -d          |Start all services\n"
          _palette_out+="server  |docker compose down           |Stop all services\n"
          _palette_out+="server  |docker compose logs -f        |Follow service logs\n"
          _palette_out+="db      |docker exec -it postgres psql -U postgres|Connect to Postgres\n"
          command -v python3 &>/dev/null && _palette_out+="python  |python3 -m venv .venv         |Create virtual env\n"
          command -v python3 &>/dev/null && _palette_out+="python  |source .venv/bin/activate     |Activate virtual env\n"
          command -v go &>/dev/null && _palette_out+="go      |go run .                      |Run Go project\n"
          command -v go &>/dev/null && _palette_out+="go      |go test ./...                 |Run all tests\n"
          ;;
        devops)
          command -v docker &>/dev/null && _palette_out+="docker  |docker ps                     |List running containers\n"
          command -v docker &>/dev/null && _palette_out+="docker  |docker system prune -f        |Remove unused resources\n"
          command -v kubectl &>/dev/null && _palette_out+="k8s     |kubectl get pods -A           |List all pods\n"
          command -v kubectl &>/dev/null && _palette_out+="k8s     |kubectl get nodes             |List cluster nodes\n"
          command -v terraform &>/dev/null && _palette_out+="tf      |terraform plan                |Preview infra changes\n"
          command -v terraform &>/dev/null && _palette_out+="tf      |terraform apply               |Apply infra changes\n"
          ;;
        data)
          command -v python3 &>/dev/null && _palette_out+="python  |python3 -m venv .venv         |Create virtual env\n"
          command -v python3 &>/dev/null && _palette_out+="python  |pip install -r requirements.txt|Install dependencies\n"
          command -v jupyter &>/dev/null && _palette_out+="jupyter |jupyter lab                   |Start JupyterLab\n"
          _palette_out+="data    |python3 -c \"import pandas; print(pandas.__version__)\"|Check pandas version\n"
          ;;
      esac

      # Add tools the user has installed
      command -v lazygit &>/dev/null && _palette_out+="git     |lazygit                       |Git TUI\n"
      command -v dust    &>/dev/null && _palette_out+="files   |dust                          |Visual disk usage\n"
      command -v zoxide  &>/dev/null && _palette_out+="nav     |z <dir>                       |Smart jump (zoxide)\n"
      command -v atuin   &>/dev/null && _palette_out+="history |atuin stats                   |Most-used commands\n"
      command -v btm     &>/dev/null && _palette_out+="sys     |btm                           |System monitor (btm)\n"

      if [[ -n "$_palette_out" ]]; then
        printf '%b' "$_palette_out" > "$_ZI_PALETTE_FILE"
        _s_ok "Palette saved to $_ZI_PALETTE_FILE"
        _s_info "$(echo "$_palette_out" | wc -l | tr -d ' ') custom entries added based on your setup"
      fi

      # ── Done ────────────────────────────────────────────────────────────
      _s_line
      printf '\033[1;32m  All done! Here is your personalized quick-start:\033[0m\n'
      _s_line

      case "$_WORKFLOW" in
        web)
          _s_tip "zi start my dev server"
          _s_tip "zi why is my npm install failing"
          _s_tip "zi write a React hook that debounces input"
          ;;
        backend)
          _s_tip "zi start my docker services"
          _s_tip "zi why did my API return a 500 error"
          _s_tip "zi write a Python function to paginate a database query"
          ;;
        devops)
          _s_tip "zi list all running containers"
          _s_tip "zi why is my pod crashing"
          _s_tip "zi write a bash script to rotate log files"
          ;;
        data)
          _s_tip "zi activate my virtual environment"
          _s_tip "zi what does this pandas error mean"
          _s_tip "zi write a script to load a CSV and show summary stats"
          ;;
        *)
          _s_tip "zi ask me something in plain English"
          _s_tip "zi fix  (after any command fails)"
          _s_tip "zi      (open the command palette)"
          ;;
      esac

      # ── Ctrl+Space spotlight ─────────────────────────────────────────────
      _s_line
      printf '\033[1;36m  ★ Secret weapon: Ctrl+Space\033[0m\n'
      _s_line
      _s_info "Type any command (even a wrong one), then press Ctrl+Space."
      _s_info "zi will silently correct it in-place before you hit Enter."
      _s_line
      if [[ $_BEGINNER -eq 1 ]]; then
        _s_info "Example: type  gti status  and press Ctrl+Space"
        _s_info "         → zi rewrites it to  git status  instantly"
        _s_line
        _s_info "One more tip: if a command fails, just type 'zi fix' and"
        _s_info "zi will explain what went wrong and how to fix it."
      else
        _s_info "Works on half-typed commands, wrong flags, typos — anything."
        _s_info "It reads your intent, not just the spelling."
      fi
      _s_line
      printf '  Restart your shell or run: \033[1msource ~/.zshrc\033[0m\n'
      _s_line
      ;;

    *)
      cat << 'HELP'
zi — terminal intelligence

  zi                  command palette
  zi setup            interactive setup wizard (run this first)
  zi <anything>       smart intent routing (auto-detects mode)
  zi ask <q>          natural language → shell command
  zi chat [session]   persistent multi-turn conversation
  zi chat list        list all saved chat sessions
  zi code <task>      generate code (Claude CLI or Groq)
  zi edit <task>      Claude edits files autonomously (prompts for bash)
  zi agent <task>     Claude fully autonomous — edits + runs commands
  zi desc <cmd>       explain what a command/snippet does
  zi fix              explain + fix last error
  zi man <cmd>        summarize man page (10 practical bullets)
  zi ? <text>         explain terminal output
  zi explain <file>   explain what a file does
  zi run <cmd>        run and copy output to clipboard
  zi log [filter]     view recent queries (optional search term)
  zi watch on|off     auto-fix on non-zero exit
  zi update           update zi to the latest version
  zi version          show current version

  Ctrl+Space          AI-correct current buffer (ZLE)

  Config:
  ZI_GROQ_KEY=<key>   Groq API key (or set GROQ_API_KEY)
  ZI_MODEL=<id>       Override Groq model
  ZI_CLAUDE=<path>    Path to claude CLI binary
  ~/.config/zi/palette  Custom palette entries (appended to defaults)
HELP
      ;;
  esac
}

_zi_main "$@"
